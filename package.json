{
  "name": "nmlp-mcp",
  "version": "0.3.1",
  "description": "Local + hosted MCP server for antiquarian first-edition identification (points of issue, number-line decoding, publisher rules over a CC-BY, DOI-cited dataset of 6,700+ titles / 850+ publishers) and New Mexico book-donation logistics. 12 tools.",
  "license": "MIT",
  "author": "Josh Eldred <jseldred@gmail.com>",
  "homepage": "https://newmexicoliteracyproject.org/first-editions",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshseane/-nmlp-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/joshseane/-nmlp-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "first-edition",
    "book-collecting",
    "points-of-issue",
    "antiquarian-books",
    "bibliography",
    "cloudflare-pages",
    "new-mexico"
  ],
  "type": "module",
  "main": "index.js",
  "bin": {
    "nmlp-mcp": "index.js"
  },
  "files": [
    "index.js",
    "functions",
    "server.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node index.js",
    "smoke": "curl -sf -X POST https://newmexicoliteracyproject.org/api/mcp -H 'Content-Type: application/json' -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\",\"params\":{}}' | grep -q nmlp_identify_first_edition"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  }
}
